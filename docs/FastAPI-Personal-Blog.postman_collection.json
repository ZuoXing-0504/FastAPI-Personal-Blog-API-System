{
  "info": {
    "_postman_id": "d1948f8f-a339-4e98-b15f-76cc854b985d",
    "name": "FastAPI Personal Blog API System",
    "description": "Postman collection for the FastAPI personal blog backend project.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:8000"
    },
    {
      "key": "username",
      "value": ""
    },
    {
      "key": "email",
      "value": ""
    },
    {
      "key": "password",
      "value": ""
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "category_name",
      "value": ""
    },
    {
      "key": "category_id",
      "value": ""
    },
    {
      "key": "article_title",
      "value": ""
    },
    {
      "key": "article_id",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/health",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "health"
          ]
        }
      }
    },
    {
      "name": "Register",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const currentUsername = pm.collectionVariables.get('username');",
              "if (!currentUsername) {",
              "  const suffix = Date.now();",
              "  pm.collectionVariables.set('username', `demo_${suffix}`);",
              "  pm.collectionVariables.set('email', `demo_${suffix}@example.com`);",
              "}",
              "if (!pm.collectionVariables.get('password')) {",
              "  pm.collectionVariables.set('password', 'abc12345');",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{username}}\",\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/v1/auth/register",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "auth",
            "register"
          ]
        }
      }
    },
    {
      "name": "Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "if (json.data && json.data.access_token) {",
              "  pm.collectionVariables.set('token', json.data.access_token);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/v1/auth/login",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "auth",
            "login"
          ]
        }
      }
    },
    {
      "name": "Current User",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/v1/users/me",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "users",
            "me"
          ]
        }
      }
    },
    {
      "name": "Create Category",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if (!pm.collectionVariables.get('category_name')) {",
              "  pm.collectionVariables.set('category_name', `技术_${Date.now()}`);",
              "}"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "if (json.data && json.data.id) {",
              "  pm.collectionVariables.set('category_id', json.data.id);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"{{category_name}}\",\n  \"description\": \"用于 Postman 集合测试的分类\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/v1/categories",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "categories"
          ]
        }
      }
    },
    {
      "name": "List Categories",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/v1/categories",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "categories"
          ]
        }
      }
    },
    {
      "name": "Create Article",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if (!pm.collectionVariables.get('article_title')) {",
              "  pm.collectionVariables.set('article_title', `FastAPI 项目演示文章_${Date.now()}`);",
              "}"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "if (json.data && json.data.id) {",
              "  pm.collectionVariables.set('article_id', json.data.id);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"{{article_title}}\",\n  \"summary\": \"用于 Postman 集合测试的文章摘要\",\n  \"content\": \"这是一篇用于 Postman 集合测试的文章正文。\",\n  \"category_id\": {{category_id}}\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/v1/articles",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "articles"
          ]
        }
      }
    },
    {
      "name": "List Articles",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/v1/articles?page=1&page_size=10&category_id={{category_id}}",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "articles"
          ],
          "query": [
            {
              "key": "page",
              "value": "1"
            },
            {
              "key": "page_size",
              "value": "10"
            },
            {
              "key": "category_id",
              "value": "{{category_id}}"
            }
          ]
        }
      }
    },
    {
      "name": "Article Detail",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/v1/articles/{{article_id}}",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "articles",
            "{{article_id}}"
          ]
        }
      }
    },
    {
      "name": "Update Article",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"{{article_title}}_已修改\",\n  \"summary\": \"作者本人修改文章成功\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/v1/articles/{{article_id}}",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "articles",
            "{{article_id}}"
          ]
        }
      }
    },
    {
      "name": "Delete Article",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/v1/articles/{{article_id}}",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "articles",
            "{{article_id}}"
          ]
        }
      }
    },
    {
      "name": "Unauthorized Create Category",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"未登录分类\",\n  \"description\": \"should fail\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/v1/categories",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "categories"
          ]
        }
      }
    }
  ]
}
